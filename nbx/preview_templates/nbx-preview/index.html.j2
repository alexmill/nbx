{%- extends 'lab/index.html.j2' -%}

{% block extra_css %}
{{ super() }}
{{ resources.include_css("static/preview.css") }}
{% endblock extra_css %}

{%- block any_cell scoped -%}
  {%- set tags = cell.metadata.get('tags', []) -%}
  {%- set caption = cell.metadata.get('caption', '') -%}
  {%- if 'nbx-hide' in tags -%}
  {%- elif 'nbx-collapse' in tags -%}
    <details class="nbx-collapsed-cell">
      <summary class="nbx-collapse-toggle">
        {%- if cell.cell_type == 'code' -%}Show code{%- else -%}Show content{%- endif -%}
      </summary>
      {{ super() }}
    </details>
  {%- elif caption -%}
    <figure class="nbx-figure">
      {{ super() }}
      <figcaption class="nbx-figcaption">{{ caption | e }}</figcaption>
    </figure>
  {%- else -%}
    {{ super() }}
  {%- endif -%}
{%- endblock any_cell -%}

{%- block body_header -%}
<body class="jp-Notebook nbx-published" data-jp-theme-light="true" data-jp-theme-name="NBX Preview">
<main class="nbx-published-shell">
  <section class="nbx-published-canvas">
    <header class="nbx-published-header">
      <p class="nbx-published-eyebrow">Saved Notebook Preview</p>
      <h1 class="nbx-published-title">{{ nb.metadata.get('title', resources['metadata']['name']) | escape_html_keep_quotes }}</h1>
      <p class="nbx-published-dek">Rendered from the notebook’s saved prose, LaTeX, code, and outputs.</p>
    </header>
    <section class="nbx-published-notebook">
{%- endblock body_header -%}

{% block body_footer %}
    </section>
  </section>
</main>
<script>
(function() {
  var modes = {
    'celltag_nbx-fig-hero':       'min(96vw, 1400px)',
    'celltag_nbx-fig-full':       'min(100%, 940px)',
    'celltag_nbx-fig-inset':      'min(100%, 560px)',
    'celltag_nbx-fig-fullscreen': '100vw',
    'celltag_nbx-wide':           'min(96vw, 1400px)'
  };
  document.querySelectorAll('[class*="celltag_nbx-fig-"], .celltag_nbx-wide').forEach(function(el) {
    for (var cls in modes) {
      if (el.classList.contains(cls)) {
        el.style.width = modes[cls];
        el.style.maxWidth = 'none';
        return;
      }
    }
    for (var i = 0; i < el.classList.length; i++) {
      var m = el.classList[i].match(/^celltag_nbx-fig-max-(\d+)px$/);
      if (m) {
        el.style.width = 'min(96vw, ' + m[1] + 'px)';
        el.style.maxWidth = 'none';
        return;
      }
    }
  });
})();
</script>
</body>
{% endblock body_footer %}
